# Proxy settings
# If you have proxy set in your environment, you don't need to set it here.
# HTTP_PROXY="http://server:port"
# HTTPS_PROXY="http://server:port"

# Google Gemini API Key
# If you have GOOGLE_API_KEY set in your environment, you don't need to set it here.
# Otherwise, uncomment and set your key:
# GOOGLE_API_KEY=your-api-key-here
# GOOGLE_GENAI_USE_VERTEXAI=
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=
# GOOGLE_VERTEXAI_PROJECT=
# GOOGLE_VERTEXAI_LOCATION=

# Model settings
MODEL_ID=gemini-3-flash-preview
IMAGE_MODEL_ID=imagen-3.0-generate-001

# Output Language
OUTPUT_LANGUAGE=Chinese

# Directory for inputs
INPUT_DIR=smartfeeds_config/

# Browser User Data Directory
BROWSER_USER_DATA_DIR="/path/to/your/browser/data"

# Directory for outputs
OUTPUT_DIR=notes/Feeds

# Directory for agent workspace 
# This is the parent directory of INPUT_DIR, BROWSER_USER_DATA_DIR, OUTPUT_DIR,
# If they are relative
WORKSPACE_DIR="/path/to/your/workspace"
